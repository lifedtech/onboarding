{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "onboarding",
  "compatibility_date": "2026-06-03",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "frontend/dist"
  },
  "build": {
    "command": "npm install --prefix frontend && VITE_API_URL=https://onboarding-sb2o.onrender.com/api npm run build --prefix frontend"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
