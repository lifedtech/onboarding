// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Phase {
  PRE_QUALIFY
  PREPARE
  REGISTER
  REVIEW
  LIVE
}

enum HealthmateType {
  PRACTITIONER
  CENTRE
  ORGANIZER
}

enum RegistrationStatus {
  PENDING
  VERIFIED
  ESCALATED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model OpsUser {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  name         String
  role         String      @default("ops") // e.g. "ops", "admin", "marketing"
  accessScopes String[]    @default([])
  publicKey    String?     @db.Text
  avatar       String?     // URL to profile picture
  statusMode   String      @default("online") // "online", "busy", "dnd", "offline"
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  tokenVersion Int         @default(0)

  // An OpsUser can own many Healthmates
  healthmates  Healthmate[]
  participants Participant[]
  messages     OpsMessage[]
  enquiries    Enquiry[]
  sessionLogs  SessionLog[]
  raisedTickets   Ticket[] @relation("RaisedTickets")
  assignedTickets Ticket[] @relation("AssignedTickets")
}

model SessionLog {
  id         String   @id @default(uuid())
  opsUserId  String
  opsUser    OpsUser  @relation(fields: [opsUserId], references: [id], onDelete: Cascade)
  loginAt    DateTime @default(now())
  lastActive DateTime @default(now())
}

model Enquiry {
  id            String    @id @default(uuid())
  name          String
  email         String?
  contact       String
  alternateContact String?
  contacted     Boolean   @default(false)
  remarks       String?   @db.Text
  clientType    String    // "SERVICE_USER" or "HEALTH_PARTNER"
  callbackLater Boolean   @default(false)
  reminderDate  DateTime?
  city          String?
  state         String?
  country       String?

  subcategory        String?
  platformFound      String?
  programPossibility String?
  format             String?
  priceRange         String?
  capacity           String?

  scoreRelevance     Int @default(0)
  scoreSafety        Int @default(0)
  scoreExperience    Int @default(0)
  scoreCredibility   Int @default(0)
  scoreLocation      Int @default(0)
  scoreVisual        Int @default(0)
  scoreBooking       Int @default(0)
  scoreUniqueness    Int @default(0)
  scoreCorporate     Int @default(0)
  scoreRepeatability Int @default(0)

  movedToPipeline Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  opsUserId     String
  opsUser       OpsUser   @relation(fields: [opsUserId], references: [id], onDelete: Cascade)
}

model Healthmate {
  id          String         @id @default(uuid())
  name        String
  type        HealthmateType
  category    String         // e.g. "Yoga", "Physiotherapy", "Wellness"
  phase       Phase          @default(PRE_QUALIFY)
  daysInPhase Int            @default(0)

  // Contact info
  contactName  String?
  contactEmail String?
  contactPhone   String?
  alternatePhone String?
  city           String?
  state          String?
  country        String?

  subcategory        String?
  platformFound      String?
  programPossibility String?
  format             String?
  priceRange         String?
  capacity           String?

  // Internal notes for ops team
  notes        String?

  // Document upload
  regDocUrl    String?
  regDocName   String?

  // Screening info & recall reminders
  screeningRemarks String?
  screeningQueries String?
  recallReminder   DateTime?

  // Program Details & R&D Review
  programTitle       String?
  programStartDate   DateTime?
  programEndDate     DateTime?
  programStatus      String?   @default("PENDING") // e.g. "PENDING", "APPROVED"
  programApprovedMsg String?

  // R&D Credentials Verification & Phase Lock
  registrationStatus RegistrationStatus @default(PENDING)
  registrationRemark String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  opsUserId     String
  opsUser       OpsUser  @relation(fields: [opsUserId], references: [id])
  tasks         Task[]
  qualification HealthmateQualification?
  tickets       Ticket[]
}

model HealthmateQualification {
  id           String @id @default(uuid())
  healthmateId String @unique
  healthmate   Healthmate @relation(fields: [healthmateId], references: [id], onDelete: Cascade)

  scoreRelevance     Int @default(0)
  scoreSafety        Int @default(0)
  scoreExperience    Int @default(0)
  scoreCredibility   Int @default(0)
  scoreLocation      Int @default(0)
  scoreVisual        Int @default(0)
  scoreBooking       Int @default(0)
  scoreUniqueness    Int @default(0)
  scoreCorporate     Int @default(0)
  scoreRepeatability Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id           String     @id @default(uuid())
  title        String
  completed    Boolean    @default(false)
  dueDate      DateTime?
  phase        Phase      // The phase this task belongs to

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relationships
  healthmateId String
  healthmate   Healthmate @relation(fields: [healthmateId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String        @id @default(uuid())
  type      String        // "DIRECT" or "GROUP"
  name      String?       // Optional group name
  createdBy String?       // Creator user ID (Admin)
  createdAt DateTime      @default(now())

  participants Participant[]
  messages     OpsMessage[]
}

model Participant {
  id             String       @id @default(uuid())
  userId         String
  conversationId String
  encryptedKey   String?      @db.Text // Symmetric group key encrypted for this user

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           OpsUser      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
}

model OpsMessage {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  encryptedText  String       @db.Text // Ciphertext
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         OpsUser      @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

enum TicketType {
  SYSTEM
  HEALTHMATE
  SERVICE_USER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

model Ticket {
  id            String   @id @default(uuid())
  title         String
  description   String?  @db.Text
  type          TicketType
  status        TicketStatus @default(OPEN)
  priority      TicketPriority @default(MEDIUM)
  
  // For SYSTEM tickets
  raisedByOpsId String?
  raisedByOps   OpsUser? @relation("RaisedTickets", fields: [raisedByOpsId], references: [id])

  // For HEALTHMATE tickets
  healthmateId  String?
  healthmate    Healthmate? @relation(fields: [healthmateId], references: [id])
  
  // For SERVICE_USER tickets
  serviceUserEmail String?

  // Assigned Ops Teammate
  assignedToId  String?
  assignedTo    OpsUser? @relation("AssignedTickets", fields: [assignedToId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
