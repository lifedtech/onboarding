// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Phase {
  PRE_QUALIFY
  PREPARE
  REGISTER
  REVIEW
  LIVE
}

enum HealthmateType {
  PRACTITIONER
  CENTRE
  ORGANIZER
}

enum RegistrationStatus {
  PENDING
  VERIFIED
  ESCALATED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model OpsUser {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  name         String
  role         String      @default("ops") // e.g. "ops", "admin"
  publicKey    String?     @db.Text
  avatar       String?     // URL to profile picture
  statusMode   String      @default("online") // "online", "busy", "dnd", "offline"
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // An OpsUser can own many Healthmates
  healthmates  Healthmate[]
  participants Participant[]
  messages     OpsMessage[]
}

model Healthmate {
  id          String         @id @default(uuid())
  name        String
  type        HealthmateType
  category    String         // e.g. "Yoga", "Physiotherapy", "Wellness"
  phase       Phase          @default(PRE_QUALIFY)
  daysInPhase Int            @default(0)

  // Contact info
  contactName  String?
  contactEmail String?
  contactPhone String?

  // Internal notes for ops team
  notes        String?

  // Document upload
  regDocUrl    String?
  regDocName   String?

  // Screening info & recall reminders
  screeningRemarks String?
  screeningQueries String?
  recallReminder   DateTime?

  // Program Details & R&D Review
  programTitle       String?
  programStartDate   DateTime?
  programEndDate     DateTime?
  programStatus      String?   @default("PENDING") // e.g. "PENDING", "APPROVED"
  programApprovedMsg String?

  // R&D Credentials Verification & Phase Lock
  registrationStatus RegistrationStatus @default(PENDING)
  registrationRemark String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  opsUserId   String
  opsUser     OpsUser  @relation(fields: [opsUserId], references: [id])
  tasks       Task[]
}

model Task {
  id           String     @id @default(uuid())
  title        String
  completed    Boolean    @default(false)
  dueDate      DateTime?
  phase        Phase      // The phase this task belongs to

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relationships
  healthmateId String
  healthmate   Healthmate @relation(fields: [healthmateId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String        @id @default(uuid())
  type      String        // "DIRECT" or "GROUP"
  name      String?       // Optional group name
  createdBy String?       // Creator user ID (Admin)
  createdAt DateTime      @default(now())

  participants Participant[]
  messages     OpsMessage[]
}

model Participant {
  id             String       @id @default(uuid())
  userId         String
  conversationId String
  encryptedKey   String?      @db.Text // Symmetric group key encrypted for this user

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           OpsUser      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
}

model OpsMessage {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  encryptedText  String       @db.Text // Ciphertext
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         OpsUser      @relation(fields: [senderId], references: [id], onDelete: Cascade)
}
