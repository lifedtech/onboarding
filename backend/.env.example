# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/lifed_healthmate"

# ─── Authentication ───────────────────────────────────────────────────────────
# A long, random string used to sign JWT tokens
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_super_secret_jwt_key_replace_this"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Redis (required for message queue) ──────────────────────────────────────
REDIS_URL="redis://localhost:6379"
