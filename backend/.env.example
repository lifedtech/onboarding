# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/lifed_healthmate"

# ─── Authentication ───────────────────────────────────────────────────────────
# A long, random string used to sign JWT tokens
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_super_secret_jwt_key_replace_this"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Redis (required for message queue) ──────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── R&D Webhooks & API Keys ──────────────────────────────────────────────────
# Shared secret for verifying signatures on incoming webhooks from R&D
RD_WEBHOOK_SECRET="your_shared_webhook_secret_key_here"

# SendGrid Configuration
SENDGRID_API_KEY="SG.your_sendgrid_api_key_here"
SENDGRID_FROM_EMAIL="support@lifedhealth.com"

# Twilio Configuration (WhatsApp)
TWILIO_ACCOUNT_SID="AC_your_twilio_account_sid_here"
TWILIO_AUTH_TOKEN="your_twilio_auth_token_here"
TWILIO_PHONE_NUMBER="+1234567890"
